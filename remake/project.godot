; Engine configuration file.
; Sports Heads Football Championship — Godot 4 remake

config_version=5

[application]

config/name="Sports Heads Championship"
config/description="Godot 4 remake with fixed-timestep physics and real-time timers."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.svg"
run/max_fps=0

[autoload]

GameConstants="*res://scripts/autoload/game_constants.gd"
GameState="*res://scripts/autoload/game_state.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"
AchievementManager="*res://scripts/autoload/achievement_manager.gd"

[display]

window/size/viewport_width=800
window/size/viewport_height=540
window/stretch/mode="canvas_items"
window/title="Sports Heads Championship"

[physics]

common/physics_ticks_per_second=90
2d/default_gravity=Vector2(0, 980)

[rendering]

renderer/rendering_method="gl_compatibility"

